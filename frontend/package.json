{
  "name": "speedrulingo-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "format": "biome format .",
    "lint": "biome lint .",
    "check": "biome check .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "generate:api": "./scripts/generate-api.sh",
    "knip": "knip",
    "knip:exports": "knip --exports",
    "check:imports": "depcruise src --config .dependency-cruiser.cjs --output-type err",
    "verify": "biome check . && tsc -b --noEmit && npm run check:imports && vitest run",
    "verify:ci": "biome check . && tsc -b --noEmit && npm run check:imports && vitest run --coverage && knip"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@hey-api/client-fetch": "^0.13.1",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-router": "^1.131.43",
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.56.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@hey-api/openapi-ts": "0.66.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.5",
    "autoprefixer": "^10.4.27",
    "dependency-cruiser": "^16.10.4",
    "jsdom": "^25.0.0",
    "knip": "^6.3.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.4.1",
    "vitest": "^2.1.5"
  }
}
